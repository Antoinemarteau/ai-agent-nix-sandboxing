# Loads the jailed-agents dev environment (tools on PATH) when entering this tree.

watch_file nix_src/flake.nix \
           nix_src/flake.lock \
           nix_src/jailed-agents.nix \
           nix_src/devshell-home.nix

if declare -f use_flake >/dev/null 2>&1; then # if nix-direnv is installed
  use flake ./nix_src
else # no nix direnv (but still nix)
  eval "$(nix print-dev-env ./nix_src)"
fi
